# Copy this to .env and fill in your values
# .env is gitignored — never commit secrets

# ─── Supabase (PostgreSQL) ────────────────────────────────────────────────────
# Connection string for the trading-data Supabase project.
# Use the Session Mode pooler URL from:
#   Supabase Dashboard → Settings → Database → Connection pooling
# Format: postgresql://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=postgresql://postgres.zouzpjewymermyauigfz:YOUR_PASSWORD@aws-0-us-west-1.pooler.supabase.com:5432/postgres

# ─── Trading DB (local SQLite path) ──────────────────────────────────────────
# Defaults to trading.db in the working directory if not set
# TRADING_DB_PATH=trading.db

# ─── Data Provider API Keys ───────────────────────────────────────────────────
# Only needed for the providers you use. Yahoo Finance needs no key.
# POLYGON_API_KEY=
# FMP_API_KEY=
# MARKETDATA_API_KEY=
# TWELVEDATA_API_KEY=
# FRED_API_KEY=

# ─── Development ──────────────────────────────────────────────────────────────
# Set to false to disable API key auth (useful for local dev without Supabase)
# This is automatic when SUPABASE_DB_URL is not set.
# TRADING_API_KEY_REQUIRED=false
